{
  "name": "splitplata",
  "version": "0.0.0",
  "private": true,
  "description": "Offline-first, no-auth expense splitting — web + mobile from one shared core.",
  "scripts": {
    "build:core": "pnpm --filter @splitplata/core build",
    "dev:core": "pnpm --filter @splitplata/core dev",
    "dev:web": "pnpm --filter @splitplata/web dev",
    "dev:mobile": "pnpm --filter @splitplata/mobile start",
    "test": "pnpm --filter @splitplata/core test",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.1"
}
